{
	"name": "quick-blocks",
	"version": "1.0.0",
	"description": "A slash menu for inserting Markdown blocks, custom snippets, attachments, dates, callouts, and editor commands.",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
